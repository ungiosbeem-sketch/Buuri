{
  "expo": {
    "name": "Abdalla Keynan",
    "slug": "abdalla-keynan",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "abdallakeynan",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#3B82F6"
    },
    "android": {
      "package": "com.abdallakeynan.chat",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3B82F6"
      }
    },
    "ios": {
      "bundleIdentifier": "com.abdallakeynan.chat",
      "supportsTablet": true
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-image-picker",
      "expo-av"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "4f5374fa-1398-423f-97fd-020f5ff9c9e3"
      },
      "router": {
        "origin": false
      }
    }
  }
}
