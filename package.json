{
  "name": "buuri-chat",
  "version": "1.0.0",
  "description": "Production-ready mobile chat application built with Expo, React Native, and Firebase",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "preview": "eas build --platform all --auto-submit=false",
    "submit": "eas submit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky install"
  },
  "dependencies": {
    "expo": "~51.0.0",
    "expo-router": "~3.5.0",
    "expo-splash-screen": "~0.27.0",
    "expo-status-bar": "~1.12.0",
    "expo-image-picker": "~15.0.0",
    "expo-notifications": "~0.28.0",
    "expo-secure-store": "~13.0.0",
    "expo-av": "~14.0.0",
    "expo-camera": "~15.0.0",
    "expo-font": "~12.0.0",
    "expo-system-ui": "~3.0.0",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.0",
    "react-native-screens": "~3.31.0",
    "react-native-svg": "15.0.0",
    "react-native-vector-icons": "^10.0.0",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native-stack": "^6.9.26",
    "@react-navigation/stack": "^6.3.29",
    "firebase": "^10.8.0",
    "react-redux": "^8.1.3",
    "@reduxjs/toolkit": "^1.9.7",
    "@tanstack/react-query": "^5.28.0",
    "axios": "^1.6.5",
    "react-hook-form": "^7.50.0",
    "yup": "^1.3.3",
    "@yup/date": "^0.2.0",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "react-native-fast-image": "^8.6.3",
    "react-native-share": "^10.2.1",
    "i18next": "^23.7.6",
    "react-i18next": "^13.5.0",
    "i18next-storage-backend": "^1.1.1",
    "i18next-http-backend": "^2.4.2",
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21",
    "uuid": "^9.0.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-native": "^4.1.0",
    "prettier": "^3.1.0",
    "jest": "^29.7.0",
    "jest-expo": "^51.0.0",
    "@testing-library/react-native": "^12.4.0",
    "@testing-library/jest-native": "^5.4.3",
    "babel-jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.2",
    "@expo/config-plugins": "^7.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
