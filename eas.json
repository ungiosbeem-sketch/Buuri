# Faylka eas.json ku beddel:

cat > eas.json << 'EOF'
{
  "cli": {
    "version": ">= 7.0.0",
    "appVersionSource": "local",
    "promptToConfigurePushNotifications": false,
    "requireCommit": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "base": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "autoIncrement": false
    },
    "production": {
      "autoIncrement": false,
      "channel": "production",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
EOF
